---
# Production Omarchy/Arch workstation. Runs the playbook locally (no SSH hop).
ansible_connection: local
ansible_user: lion
ansible_python_interpreter: /usr/bin/python3

desktop_user: lion
base_dotfiles_enabled: true
base_lazydocker_enabled: true
workstation_enabled: true
workstation_cli_enabled: true
workstation_dotfiles_enabled: true
workstation_espanso_enabled: false

dotfiles_stow_packages:
  - bash
  - starship
  - claude
  - tmux
  - ssh
  - opencode
  - nvim
  - git
  - gh
  - lazygit
  - hypr
  - wireplumber
  - systemd
  - scripts

# Secret dotfiles deployed by copy-decrypt (not Stow). The vaulted source holds
# the real SSH host aliases; the public ssh package only ships the sanitized
# config that Includes this file. Needs a vault password at run time.
dotfiles_secret_files:
  - src: "{{ dotfiles_secret_source_dir }}/ssh/config.local"
    dest: .ssh/config.local
    mode: "0600"
    dir_mode: "0700"

# Systemd user services to enable after stow deploys them.
workstation_systemd_user_services:
  - audio-policy.service
  - freebox-mount.service
