[server]
# NOTE: raspberrypi has no host_vars file → inherits all role defaults →
# base_dotfiles_enabled: false, no secrets deployed. To activate dotfiles,
# create host_vars/raspberrypi with base_dotfiles_enabled: true.
raspberrypi
serverannah

[workstation]
# Test VM first. With GNOME Boxes NAT, forward host port 2222 to guest port 22
# and set ansible_port accordingly in host_vars/savannarchome.
savannarchome
# Raspberry Pi 4 (Debian trixie, aarch64) used as a CLI/TUI dev + AI test bench.
raspi
