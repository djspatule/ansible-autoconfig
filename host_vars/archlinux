---
ansible_connection: local
ansible_python_interpreter: auto_silent
autoconfig_playbook: server_core.yml
server_homepage_enabled: true
server_bentopdf_enabled: true
# The VM is where reverse-proxy changes are exercised first.
server_reverse_proxy_enabled: true
homepage_extra_allowed_hosts:
  - 127.0.0.1:3000
  - homepage.localtest.me
  - homepage.localtest.me:8081
server_reverse_proxy_published_ports:
  - 8081:80
server_reverse_proxy_sites:
  - hostname: homepage.localtest.me
    upstream: homepage:3000
  - hostname: bentopdf.localtest.me
    upstream: bentopdf:8080
