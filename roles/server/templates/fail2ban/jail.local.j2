[DEFAULT]
# Keep the defaults readable and host-driven so tightening or loosening bans is
# just a variable change instead of manual edits under /etc.
bantime = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
ignoreip = {{ fail2ban_ignoreips | join(' ') }}

[sshd]
enabled = {{ fail2ban_sshd_enabled | ternary('true', 'false') }}
backend = {{ fail2ban_sshd_backend }}
port = {{ fail2ban_sshd_port }}

[caddy-basic-auth]
enabled = {{ fail2ban_caddy_basic_auth_enabled | ternary('true', 'false') }}
filter = caddy-basic-auth
backend = polling
logpath = {{ fail2ban_caddy_basic_auth_logpath }}
maxretry = {{ fail2ban_caddy_basic_auth_maxretry }}
findtime = {{ fail2ban_caddy_basic_auth_findtime }}
bantime = {{ fail2ban_caddy_basic_auth_bantime }}
port = http,https
