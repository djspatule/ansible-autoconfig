#!/bin/sh
set -eu

repo_url="{{ autoconfig_repo_url }}"
branch="{{ autoconfig_branch }}"
repo_dir="{{ autoconfig_repo_dir }}"
playbook="{{ autoconfig_playbook }}"

# Keep a stable checkout path on disk. This makes the managed files easy to find
# and lets ansible-pull reuse the same repo-local config every day.
if [ ! -d "$repo_dir/.git" ]; then
  git clone --branch "$branch" "$repo_url" "$repo_dir"
else
  # The checkout is a managed mirror, not a place to keep edits. Force it to match
  # the remote branch exactly so the daily pull cannot break on a dirty or
  # divergent tree (e.g. an app rewriting a tracked file through a dotfile symlink,
  # or an upstream force-push). clean runs without -x, so ignored paths survive.
  git -C "$repo_dir" fetch --prune origin
  git -C "$repo_dir" checkout -f "$branch"
  git -C "$repo_dir" reset --hard "origin/$branch"
  git -C "$repo_dir" clean -fd
fi

if [ -f "$repo_dir/requirements.yml" ]; then
  ansible-galaxy collection install -r "$repo_dir/requirements.yml"
fi

# Point Ansible at the repo-local config so inventory and defaults stay aligned
# no matter where the helper is launched from.
export ANSIBLE_CONFIG="$repo_dir/ansible.cfg"

# Build the argument list in the shell so the optional vault flag can be added
# cleanly. Doing this with Jinja line-continuations is fragile; "set --" is not.
set -- ansible-pull -U "$repo_url" -C "$branch" -d "$repo_dir"
{% if autoconfig_vault_password_file %}
set -- "$@" --vault-password-file "{{ autoconfig_vault_password_file }}"
{% endif %}
set -- "$@" "$playbook"

exec "$@"
