---
ansible_connection: local
ansible_python_interpreter: auto_silent
autoconfig_branch: server-bootstrap
autoconfig_playbook: local.yml
base_dotfiles_enabled: true
server_homepage_enabled: true
server_bentopdf_enabled: true
server_game_timer_enabled: true
server_nextcloud_enabled: true
# Keep Pi-hole off on the real server until the final DNS cutover and admin
# hostname are chosen deliberately.
server_pihole_enabled: true
pihole_policy_import_enabled: true
# Stage Pi-hole on high ports first so we can test it without fighting the
# host's existing local resolver or changing household DNS yet.
pihole_published_ports:
  - "5300:53/tcp"
  - "5300:53/udp"
  - "8089:80"
server_reverse_proxy_enabled: true
server_aumenuilya_enabled: true
homepage_extra_allowed_hosts:
  - 192.168.1.7:3000
server_reverse_proxy_auto_https: true
server_reverse_proxy_published_ports:
  - 80:80
  - 443:443
server_reverse_proxy_sites:
  - hostname: aumenuilya.com
    redirect_to: https://www.aumenuilya.com
  - hostname: www.aumenuilya.com
    upstream: aumenuilya:80
  - hostname: tabletop-timer.com
    upstream: game-timer:80
  - hostname: cloud.dinnizer.com
    upstream: nextcloud:80
dotfiles_stow_packages:
  - bash
# Keep the current persistent data layout visible in host vars so future mount
# automation can be generated from structured data instead of a copied fstab.
server_storage_mounts:
  - src: UUID=89612d91-62bc-45b5-bc84-04e52994ca03
    path: /mnt/SSD_512
    fstype: ext4
    opts: defaults,nofail
    dump: 0
    passno: 2
  - src: UUID=a52bd55d-c955-4d7e-86b4-0ddf448304af
    path: /mnt/SSD_1TO
    fstype: ext4
    opts: defaults,nofail
    dump: 0
    passno: 2
  - src: UUID=83f9bfa8-56fe-47bd-bbc2-962b707450ec
    path: /mnt/back-up
    fstype: ext4
    opts: defaults,nofail
    dump: 0
    passno: 2
  - src: UUID=d41a355a-a5ba-47b3-8e00-a602131c933a
    path: /mnt/verbatim
    fstype: ext4
    opts: defaults,nofail
    dump: 0
    passno: 2
nextcloud_public_url: https://cloud.dinnizer.com
aumenuilya_backup_root: /mnt/SSD_1TO/BackUp/Mimi/AuMenuIlYA
aumenuilya_public_url: https://www.aumenuilya.com
